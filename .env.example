# Copy to .env and fill in your real key.
# Get one at https://console.groq.com/keys
GROQ_API_KEY=your_key_here

# Optional: override the LLM-as-judge model used by evaluate().
# EVAL_MODEL=llama-3.3-70b-versatile

# Frontend (Gradio Space) -> backend wiring. The Space reads BACKEND_URL and
# POSTs workflow descriptions to it. Set this as a SECRET on the HF Space
# (somshubhra/c7-workflow-diagnosis), pointing at the deployed /diagnose endpoint.
# BACKEND_URL=https://c7-workflow-diagnosis-tool-swqg.onrender.com/diagnose
